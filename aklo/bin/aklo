#!/bin/bash
#==============================================================================
# The Aklo Protocol - Interface Unifiée
# v5.0 - Initialisation Robuste et Fiabilisée
#==============================================================================

# --- 1. Découverte de la Racine du Projet (LA TOUTE PREMIÈRE CHOSE À FAIRE) ---
# Détermine son propre emplacement de manière robuste, indépendamment du
# répertoire depuis lequel il est appelé.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export AKLO_PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"


# --- 2. Configuration de base du Shell ---
set -o pipefail

# --- 3. Chargement des modules CORE indispensables ---
# shellcheck source=/dev/null
source "${AKLO_PROJECT_ROOT}/aklo/modules/core/command_classifier.sh"
# shellcheck source=/dev/null
source "${AKLO_PROJECT_ROOT}/aklo/modules/core/lazy_loader.sh"

# --- 4. Exécution du Dispatcher Principal ---
main() {
    local start_time; start_time=$(date +%s%N)

    local command="$1"
    if [ -z "$command" ]; then
        cmd_help
        exit 0
    fi

    local profile; profile=$(classify_command "$command")
    load_modules_for_profile "$profile"

    if command -v "cmd_$command" >/dev/null 2>&1; then
        "cmd_$command" "$@"
    else
        echo "Erreur: Commande '$command' inconnue ou son module n'a pu être chargé." >&2
        cmd_help
        exit 1
    fi
    
    local end_time; end_time=$(date +%s%N)
    local duration=$(( (end_time - start_time) / 1000000 ))
    # echo "Temps d'exécution: ${duration}ms" >&2
}

main "$@"